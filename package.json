{
  "name": "anchored",
  "version": "1.0.0",
  "description": "Smart note-taking for the web - anchor your ideas to specific web locations",
  "homepage": "https://anchored.site",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/anchored.git"
  },
  "keywords": [
    "notes",
    "browser-extension",
    "web-app",
    "productivity",
    "note-taking",
    "encryption",
    "privacy"
  ],
  "author": "Anchored Team",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "supabase start",
    "deploy": "supabase functions deploy",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "types": "supabase gen types typescript --local > types/database.ts",
    "cache:bust": "node scripts/update-cache-version.js",
    "cache:deploy": "node scripts/deploy-with-cache-bust.js",
    "cache:deploy:commit": "node scripts/deploy-with-cache-bust.js --commit",
    "cache:test": "node scripts/test-cache-busting.js",
    "security:deps": "node scripts/check-banned-packages.js .",
    "security:audit": "npm audit --package-lock-only --audit-level=high"
  },
  "devDependencies": {
    "dompurify": "^3.3.3",
    "supabase": "^2.84.8"
  },
  "overrides": {
    "axios@1.14.1": "1.14.0",
    "axios@0.30.4": "0.30.3",
    "plain-crypto-js@4.2.1": "0.0.1-security.0"
  },
  "engines": {
    "node": ">=24.13.0"
  }
}
